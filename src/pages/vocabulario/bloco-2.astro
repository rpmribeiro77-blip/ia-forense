---
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { parseVocabBlock } from "../../lib/vocab";

const raw = fs.readFileSync(
  path.join(process.cwd(), "public", "vocabulario-textos", "bloco-2.txt"),
  "utf-8"
);
const entries = parseVocabBlock(raw, 2);
---

<BaseLayout title="Vocabulário Tecnológico — Bloco 2">
  <span class="tag">Bloco 2</span>
  <h1>Vocabulário Tecnológico — Bloco 2</h1>
  <p class="meta">
    Este bloco organiza o vocabulário aplicável à rotina jurídica com IA, agentes e automações,
    com ênfase em método de trabalho, padronização e controle operacional.
  </p>
  <div class="entries">
    {
      entries.map((entry) => (
        <article class="entry">
          <h2>{entry.term}</h2>
          {entry.fields.map((field) => (
            <p>
              <strong>{field.label}:</strong> {field.value}
            </p>
          ))}
        </article>
      ))
    }
  </div>
</BaseLayout>

<style>
  .entries {
    display: grid;
    gap: 0.9rem;
  }
  .entry {
    border: 1px solid #bfd3e8;
    border-radius: 12px;
    background: #f7fbff;
    padding: 1rem;
  }
  .entry h2 {
    margin: 0 0 0.55rem;
    font-size: 1.18rem;
  }
  .entry p {
    margin: 0.32rem 0;
    line-height: 1.58;
  }
</style>
