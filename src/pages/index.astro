---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="IA Forense | Início">
  <section class="hero">
    <span class="tag">MVP (versão inicial)</span>
    <span class="tag">Sem custo no início</span>
    <h1>Inteligência artificial aplicada à prática forense</h1>
    <p>
      Este site nasce para ensinar aplicação prática de IA no dia a dia jurídico, com foco em produtividade,
      qualidade técnica e responsabilidade no uso.
    </p>
    <p class="meta">MVP significa uma primeira versão funcional do site, feita para publicar conteúdo logo e evoluir aos poucos.</p>
    <a href="/ia-forense/" class="cta">Explorar IA Forense</a>
    <a href="/processo-civil/" class="cta alt">Ver Processo Civil</a>
  </section>

  <section>
    <h2>Seções principais</h2>
    <div class="grid">
      <article class="card">
        <h3>IA Forense</h3>
        <p>Guias, tutoriais, prompts e noções de código para rotina forense.</p>
        <a href="/ia-forense/">Entrar</a>
      </article>
      <article class="card">
        <h3>Processo Civil <span class="status-badge">Em construção</span></h3>
        <p>Conteúdo exclusivo com enfoque técnico e utilidade prática.</p>
        <a href="/processo-civil/">Entrar</a>
      </article>
      <article class="card">
        <h3>Opinião <span class="status-badge">Em construção</span></h3>
        <p>Análises autorais sobre tendências, riscos e limites da IA no Direito.</p>
        <a href="/opiniao/">Entrar</a>
      </article>
      <article class="card">
        <h3>Biblioteca <span class="status-badge">Em construção</span></h3>
        <p>Seleção prática de vídeos, artigos, ferramentas e links de referência.</p>
        <a href="/biblioteca/">Entrar</a>
      </article>
    </div>
  </section>
</BaseLayout>
