---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="IA Forense | Início">
  <section class="hero">
    <div class="hero-split">
      <div class="hero-copy">
        <span class="tag">Versão MVP</span>
        <h1>Inteligência artificial aplicada à prática forense</h1>
        <p class="author-line">
          <strong>Por Rodrigo Pereira Martins Ribeiro</strong>
          <a href="sobre/#curriculo-autor">Currículo</a>
          <a href="sobre/#contato">Contato</a>
        </p>
        <p class="lead">
          Aplicação prática de IA no dia a dia jurídico, com foco em produtividade, qualidade crítica,
          escrita jurídica e prática forense contemporânea.
        </p>
        <div class="quick-links" aria-label="Acessos principais">
          <a href="comece-por-aqui/">Comece por aqui</a>
          <a href="ia-forense/">IA Forense</a>
          <a href="escrita-juridica/">Escrita Jurídica</a>
          <a href="laboratorio-forense/">Laboratório Forense</a>
          <a href="vocabulario/">Vocabulário</a>
          <a href="biblioteca/">Biblioteca</a>
          <a href="reflexoes/">Reflexões</a>
          <a href="sobre/">Sobre</a>
        </div>
      </div>

      <div class="hero-visual" aria-label="Mockup de painel jurídico-tecnológico">
        <svg
          class="hero-illustration"
          width="430"
          height="300"
          viewBox="0 0 860 600"
          role="img"
          aria-label="Painel fictício com documentos, filtros e análise jurídica"
          xmlns="http://www.w3.org/2000/svg"
        >
          <defs>
            <linearGradient id="panelBg" x1="0" y1="0" x2="860" y2="600" gradientUnits="userSpaceOnUse">
              <stop stop-color="#10213A"/>
              <stop offset="1" stop-color="#1E3656"/>
            </linearGradient>
            <linearGradient id="panelCard" x1="90" y1="110" x2="760" y2="510" gradientUnits="userSpaceOnUse">
              <stop stop-color="#17304D"/>
              <stop offset="1" stop-color="#0E1D32"/>
            </linearGradient>
            <linearGradient id="accentLine" x1="112" y1="132" x2="780" y2="460" gradientUnits="userSpaceOnUse">
              <stop stop-color="#8AE7F7"/>
              <stop offset="1" stop-color="#A18BFF"/>
            </linearGradient>
          </defs>

          <rect width="860" height="600" rx="36" fill="url(#panelBg)"/>
          <g opacity="0.22" stroke="#A7E7F8" stroke-width="1">
            <path d="M60 96H800"/>
            <path d="M60 184H800"/>
            <path d="M60 272H800"/>
            <path d="M60 360H800"/>
            <path d="M60 448H800"/>
