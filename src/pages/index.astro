          <rect x="126" y="190" width="84" height="12" rx="6" fill="#8AE7F7"/>
          <rect x="126" y="230" width="94" height="10" rx="5" fill="#5B708C"/>
          <rect x="126" y="262" width="70" height="10" rx="5" fill="#5B708C"/>
          <rect x="126" y="294" width="108" height="10" rx="5" fill="#5B708C"/>
          <rect x="126" y="348" width="86" height="24" rx="12" fill="#1A3652"/>
          <rect x="126" y="386" width="104" height="24" rx="12" fill="#1A3652"/>
          <rect x="126" y="424" width="72" height="24" rx="12" fill="#1A3652"/>

