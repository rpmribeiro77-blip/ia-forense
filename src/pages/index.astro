          <rect x="74" y="72" width="712" height="456" rx="30" fill="url(#panelCard)" stroke="#5B7897" stroke-width="2"/>
          <rect x="74" y="72" width="712" height="58" rx="30" fill="#1C3554"/>
          <rect x="104" y="94" width="124" height="13" rx="6.5" fill="#C7F2FF"/>
          <rect x="248" y="94" width="70" height="13" rx="6.5" fill="#536A88"/>
          <rect x="340" y="94" width="92" height="13" rx="6.5" fill="#536A88"/>
          <rect x="650" y="91" width="92" height="20" rx="10" fill="#244765" stroke="#8AE7F7" stroke-width="1.5"/>

