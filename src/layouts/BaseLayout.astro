---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "IA Forense: inteligência artificial aplicada à prática forense e processo civil." } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Serif:wght@400;500;600&display=swap");
      :root {
        --bg: #081320;
        --surface: #0f1f31;
        --text: #eef4ff;
        --muted: #aac0d9;
        --brand: #48d3ff;
        --accent: #f3b64c;
        --border: #2a4664;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        color: var(--text);
        font-family: "Space Grotesk", "Segoe UI", Tahoma, sans-serif;
        background:
          radial-gradient(circle at 12% 8%, #173352 0, transparent 40%),
          radial-gradient(circle at 82% 86%, #1a2842 0, transparent 42%),
          linear-gradient(145deg, #07101c 0%, #09192a 45%, #081320 100%);
      }
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.18;
        background-image:
          linear-gradient(to right, #9bb6d51f 1px, transparent 1px),
          linear-gradient(to bottom, #9bb6d51f 1px, transparent 1px);
        background-size: 32px 32px;
      }
      a { color: var(--brand); }
      p, li { font-family: "IBM Plex Serif", Georgia, serif; }
      .container { width: min(1120px, 92vw); margin: 0 auto; }
      header {
        position: sticky;
        top: 0;
        z-index: 20;
        backdrop-filter: blur(10px);
        background: #09192ad9;
        border-bottom: 1px solid var(--border);
      }
      .topbar {
        display: flex;
        gap: 1rem;
        justify-content: space-between;
        align-items: center;
        padding: 0.9rem 0;
      }
      .brand {
        text-decoration: none;
        color: var(--text);
        font-weight: 700;
        letter-spacing: 0.04em;
        font-size: 1.55rem;
        display: inline-flex;
        align-items: center;
      }
      .brand::before {
        content: "";
        width: 10px;
        height: 10px;
        border-radius: 2px;
        margin-right: 0.5rem;
        background: linear-gradient(45deg, var(--brand), var(--accent));
        box-shadow: 0 0 16px #48d3ff66;
      }
      nav { display: flex; flex-wrap: wrap; gap: 0.65rem; }
      nav a {
        text-decoration: none;
        font-size: 0.92rem;
        color: #d7e5f7;
        padding: 0.35rem 0.62rem;
        border-radius: 999px;
        border: 1px solid transparent;
      }
      nav a:hover {
        border-color: #33577d;
        background: #152b4299;
      }
      main { padding: 1.5rem 0 2.2rem; }
      .hero {
        border: 1px solid var(--border);
        background: linear-gradient(145deg, #0c1d30, #112640 60%, #122033);
        border-radius: 18px;
        padding: 1.55rem;
        box-shadow: 0 18px 36px #0000002b;
      }
      .grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }
      .card {
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1rem;
        background: linear-gradient(180deg, #10233a, #0e1d2f);
        box-shadow: 0 10px 22px #00000024;
      }
      .card h3 { margin-bottom: 0.4rem; }
      .tag {
        display: inline-block;
        background: #123655;
        color: #9be6ff;
        border: 1px solid #2f587a;
        border-radius: 999px;
        font-size: 0.78rem;
        padding: 0.2rem 0.62rem;
        margin-right: 0.4rem;
      }
      .meta { color: var(--muted); font-size: 0.92rem; }
      footer {
        border-top: 1px solid var(--border);
        color: var(--muted);
        padding: 1rem 0 2rem;
        font-size: 0.9rem;
      }
      h1, h2, h3 { margin-top: 0.2rem; line-height: 1.2; }
      .cta {
        display: inline-block;
        margin-top: 0.6rem;
        background: linear-gradient(120deg, #1aa3d4, #37c7f7);
        color: #031523;
        font-weight: 700;
        text-decoration: none;
        padding: 0.55rem 0.9rem;
        border-radius: 10px;
      }
      .cta.alt { background: linear-gradient(120deg, #d89d3e, #f3c062); }
      .status-badge {
        display: inline-block;
        margin-left: 0.45rem;
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
        font-size: 0.75rem;
        color: #ffeec8;
        background: #5f431b;
        border: 1px solid #a1732e;
        vertical-align: middle;
      }
      @media (max-width: 780px) {
        .topbar { align-items: flex-start; flex-direction: column; }
        nav { gap: 0.45rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container topbar">
        <a href="/" class="brand">IA Forense</a>
        <nav>
          <a href="/ia-forense/">IA Forense</a>
          <a href="/processo-civil/">Processo Civil</a>
          <a href="/opiniao/">Opinião</a>
          <a href="/biblioteca/">Biblioteca</a>
          <a href="/sobre/">Sobre</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">
        <strong>IA Forense</strong> · Direito, tecnologia e método para prática forense contemporânea.
      </div>
    </footer>
  </body>
</html>

